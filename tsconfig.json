{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",       // ESNext থেকে CommonJS
    "moduleResolution": "Node", // bundler থেকে Node
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}